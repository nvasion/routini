# Copy this file to .env and fill in the required values before running
# docker compose up.

# ── Required ────────────────────────────────────────────────────────
# Signs authentication cookies.  Generate with:
#   openssl rand -base64 32
COOKIE_SECRET=change-me-to-a-strong-random-string

# ── Optional (defaults shown) ────────────────────────────────────────
# The public URL the frontend is served from.
# In production this should match the nginx vhost (e.g. https://example.com).
# CLIENT_URL=http://localhost

# Server port (also update nginx.conf if you change this)
# PORT=3001

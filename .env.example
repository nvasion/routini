# Copy to `.env` (which is git-ignored) and fill in per-environment values.
# Never commit real credentials — this file is documentation only.

# ---------- Server ----------

# HTTP port the Express server listens on.
PORT=3001

# Comma-separated CORS allowlist. Explicit origins only — no wildcards.
# The dev client runs on 5173 by default.
ALLOWED_ORIGINS=http://localhost:5173

# Node environment. Set to `production` in production deployments to
# enable Secure cookies and activate production-only security checks.
NODE_ENV=development

# ---------- Authentication ----------

# HMAC-SHA256 secret for signing JWT tokens.
# REQUIRED in production — must be at least 32 characters. The server refuses
# to start without it when NODE_ENV=production.
# In development a built-in fallback is used automatically; never rely on it
# outside local machines.
#
# Generate a strong secret with one of:
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# JWT / auth-cookie lifetime in seconds.
# Default: 3600 (1 hour). Hard cap: 86400 (24 hours).
# Short TTLs reduce blast radius when a token is stolen; for longer sessions
# consider a dedicated refresh-token flow rather than raising this value.
JWT_TTL_SECONDS=3600

# Default admin account seeded when the user store is empty on first start.
# DEFAULT_ADMIN_PASSWORD MUST be changed from "changeme" before deploying to
# production — the server refuses to start if it is still the sentinel value.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme

# Absolute path to a JSON file used for persistent user storage.
# When unset, users are held in memory only (lost on restart — fine for dev).
# The parent directory is created automatically on first write.
# File permissions are set to 0600 (owner-readable only).
# Example: /var/lib/routini/users.json
USER_STORE_PATH=

# Login brute-force protection: sliding-window rate limit applied per
# (client IP, normalized username) pair.
#   LOGIN_RATE_LIMIT_MAX            — max attempts inside the window (default 10)
#   LOGIN_RATE_LIMIT_WINDOW_SECONDS — window length in seconds (default 60)
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# ---------- AI settings ----------

# Base64-encoded 32-byte AES-256-GCM key used to encrypt user AI provider API
# keys at rest.
#
# REQUIRED in production — the server refuses to start without it when
# NODE_ENV=production. In development an ephemeral in-process key is
# generated so `make dev` still works, but every restart invalidates all
# stored API keys — DO NOT rely on it outside local machines.
#
# Generate a strong key with one of:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_SETTINGS_ENCRYPTION_KEY=
